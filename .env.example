# Copy to .env.local for local dev. Production (Vercel + native) must set the same VITE_* at build time.

# --- Public app URL (store listings, legal canonical links) ---
VITE_PUBLIC_SITE_URL=https://veda2.vercel.app
# VITE_PUBLIC_SUPPORT_EMAIL=support@veda.health

# --- Auth (required for login / sync) ---
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=

# --- Observability (optional) ---
# VITE_SENTRY_DSN=
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# --- Native IAP (optional until store products exist) ---
# VITE_REVENUECAT_APPLE_KEY=
# VITE_REVENUECAT_GOOGLE_KEY=

# --- Server-only (Vercel project env, NOT VITE_*) ---
# DATABASE_URL=          # Neon / Postgres
# OPENAI_API_KEY=
# SUPABASE_URL=          # can mirror VITE_SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY=
# MIGRATE_SECRET=
# ADMIN_EMAILS=
