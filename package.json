{
  "name": "veda",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:cap": "VEDA_CAPACITOR=1 npm run build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "bash scripts/smoke-test.sh",
    "check:connections": "bash scripts/check-connections.sh",
    "test:imports": "bash scripts/check-imports.sh",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:critics": "node scripts/ai-vision-critic.mjs && node scripts/ai-data-sanity-critic.mjs && node scripts/critics-summary.mjs",
    "test:all": "playwright test && node scripts/ai-vision-critic.mjs && node scripts/ai-data-sanity-critic.mjs && node scripts/critics-summary.mjs",
    "cap:sync:ios": "npm run build:cap && npx cap sync ios",
    "cap:sync:android": "npm run build:cap && npx cap sync android",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "release:prepare": "bash scripts/prepare-native-release.sh",
    "ingest:dsld": "node scripts/ingest-dsld.mjs",
    "ingest:off": "node scripts/ingest-off.mjs"
  },
  "dependencies": {
    "@capacitor/browser": "^8.0.3",
    "@neondatabase/serverless": "^1.1.0",
    "@revenuecat/purchases-capacitor": "^12.3.2",
    "@sentry/react": "^10.53.1",
    "@supabase/supabase-js": "^2.105.4",
    "pg": "^8.20.0",
    "posthog-js": "^1.373.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vercel/node": "^5.8.2",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.6.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.6"
  }
}
