{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.vedais.ai" }],
      "destination": "https://vedais.ai/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "veda2.vercel.app" }],
      "destination": "https://vedais.ai/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
